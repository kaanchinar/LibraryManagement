POST {{host}}/api/Genres
Content-Type: application/json

{
  "name": "Science Fiction"
}

###

# PUT /api/Genres/{id} — update (200 OK)
PUT {{host}}/api/Genres/{{genreId}}
Content-Type: application/json

{
  "name": "Sci-Fi"
}

###

# DELETE /api/Genres/{id} — delete (204 No Content)
DELETE {{host}}/api/Genres/{{genreId}}

### ===== PUBLISHERS =====

# GET /api/Publishers — list (200 OK)
GET {{host}}/api/Publishers
Accept: application/json

###

# GET /api/Publishers/{id} — by ID (200 OK)
GET {{host}}/api/Publishers/{{publisherId}}
Accept: application/json

###

# POST /api/Publishers — create (201 Created)
POST {{host}}/api/Publishers
Content-Type: application/json

{
  "name": "Vintage Books"
}

###

# PUT /api/Publishers/{id} — update (200 OK)
PUT {{host}}/api/Publishers/{{publisherId}}
Content-Type: application/json

{
  "name": "Vintage International"
}

###

# DELETE /api/Publishers/{id} — delete (204 No Content)
DELETE {{host}}/api/Publishers/{{publisherId}}

### ===== MEMBERS =====

# GET /api/Members — list (200 OK)
GET {{host}}/api/Members
Accept: application/json

###

# GET /api/Members/{id} — by ID (200 OK)
GET {{host}}/api/Members/{{memberId}}
Accept: application/json

###

# POST /api/Members — create (201 Created)
POST {{host}}/api/Members
Content-Type: application/json

{
  "fullName": "Charlie Brown",
  "email": "charlie@example.com",
  "phoneNumber": "+1 555 0103"
}

###

# PUT /api/Members/{id} — update (200 OK)
PUT {{host}}/api/Members/{{memberId}}
Content-Type: application/json

{
  "fullName": "Charlie Brown",
  "email": "charlie@example.com",
  "phoneNumber": "+1 555 0999"
}

###

# DELETE /api/Members/{id} — delete (204 No Content)
DELETE {{host}}/api/Members/{{memberId}}

### ===== LOANS =====

# GET /api/Loans — list with filters (200 OK)
GET {{host}}/api/Loans?isOverdue=false&sortBy=loanDate&pageNumber=1&pageSize=10
Accept: application/json

###

# GET /api/Loans/{id} — by ID (200 OK)
GET {{host}}/api/Loans/{{loanId}}
Accept: application/json

###

# POST /api/Loans — checkout (201 Created)
POST {{host}}/api/Loans
Content-Type: application/json

{
  "bookId": "{{bookId}}",
  "memberId": "{{memberId}}"
}

###

# POST /api/Loans/{id}/return — return (204 No Content)
POST {{host}}/api/Loans/{{loanId}}/return

### ===== ERROR CASES =====

# GET non-existent — 404 Not Found
GET {{host}}/api/Authors/00000000-0000-0000-0000-000000000000
Accept: application/json

###

# POST invalid body — 400 Bad Request (FluentValidation)
POST {{host}}/api/Authors
Content-Type: application/json

{
  "name": "",
  "bio": "test"
}

###

# POST loan with unavailable book — 400 Bad Request (BusinessRuleException)
POST {{host}}/api/Loans
Content-Type: application/json

{
  "bookId": "00000000-0000-0000-0000-000000000000",
  "memberId": "{{memberId}}"
}
