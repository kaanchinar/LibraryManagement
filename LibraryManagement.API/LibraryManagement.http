@host = http://localhost:8080

### ===== AUTHORS =====

# GET /api/Authors — list (200 OK)
GET {{host}}/api/Authors
Accept: application/json

###
@authorId = 28843915-a2f5-4aa0-a6e1-0fcabbf1ed72

# GET /api/Authors/{id} — by ID (200 OK)
GET {{host}}/api/Authors/{{authorId}}
Accept: application/json

###

# POST /api/Authors — create (201 Created + Location header)
POST {{host}}/api/Authors
Content-Type: application/json

{
  "name": "Fyodor Dostoevsky",
  "bio": "Russian novelist and philosopher."
}

###

# PUT /api/Authors/{id} — update (200 OK)
PUT {{host}}/api/Authors/{{authorId}}
Content-Type: application/json

{
  "name": "Fyodor Dostoevsky",
  "bio": "Updated bio."
}

###

# DELETE /api/Authors/{id} — delete (204 No Content)
DELETE {{host}}/api/Authors/{{authorId}}

### ===== BOOKS =====

# GET /api/Books — list with filters (200 OK)
GET {{host}}/api/Books?title=1984&sortBy=title&pageNumber=1&pageSize=5
Accept: application/json

###
@bookId = 72dbea80-2d03-481c-85d6-43493ae4ccee

# GET /api/Books/{id} — by ID (200 OK)
GET {{host}}/api/Books/{{bookId}}
Accept: application/json

###
@genreId = c39a9edd-0993-4ae1-bf13-4a3b45ecf6e0
@publisherId = fb96fa87-9b6b-4371-94bc-b17c8f19d3c9

# POST /api/Books — create (201 Created)
POST {{host}}/api/Books
Content-Type: application/json

{
  "title": "Crime and Punishment",
  "isbn": "9780140449136",
  "publicationYear": 1866,
  "totalCopies": 3,
  "availableCopies": 3,
  "authorId": "{{authorId}}",
  "genreId": "{{genreId}}",
  "publisherId": "{{publisherId}}"
}

###

# PUT /api/Books/{id} — update (200 OK)
PUT {{host}}/api/Books/{{bookId}}
Content-Type: application/json

{
  "title": "Crime and Punishment",
  "isbn": "9780140449136",
  "publicationYear": 1866,
  "totalCopies": 5,
  "availableCopies": 5,
  "authorId": "{{authorId}}",
  "genreId": "{{genreId}}",
  "publisherId": "{{publisherId}}"
}

###

# DELETE /api/Books/{id} — delete (204 No Content)
DELETE {{host}}/api/Books/{{bookId}}

### ===== GENRES =====

# GET /api/Genres — list (200 OK)
GET {{host}}/api/Genres
Accept: application/json

###

# GET /api/Genres/{id} — by ID (200 OK)
GET {{host}}/api/Genres/{{genreId}}
Accept: application/json

###

